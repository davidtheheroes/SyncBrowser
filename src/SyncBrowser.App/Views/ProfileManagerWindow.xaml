<Window x:Class="SyncBrowser.App.Views.ProfileManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile Manager"
        Width="640" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Title ═══ -->
        <TextBlock Grid.Row="0" Text="🗂 Profile Manager" 
                   FontSize="20" FontWeight="Bold" 
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,16"/>

        <!-- ═══ Create New Profile Form ═══ -->
        <Border Grid.Row="1" Background="#161B22" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Create New Profile" FontSize="14" FontWeight="SemiBold" 
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>

                <TextBlock Text="Name" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,8"/>

                <TextBlock Text="Proxy Server (optional)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding NewProfileProxy, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,8"/>

                <TextBlock Text="User Agent (optional)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding NewProfileUserAgent, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

                <Button Content="➕ Create Profile" 
                        Command="{Binding CreateCommand}" 
                        Style="{StaticResource AccentButton}"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- ═══ Existing Profiles List ═══ -->
        <Border Grid.Row="2" Background="#161B22" CornerRadius="8" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Existing Profiles" FontSize="14" FontWeight="SemiBold" 
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="4,0,0,8"/>

                <ListBox Grid.Row="1" MinHeight="200" 
                         ItemsSource="{Binding Profiles}" 
                         SelectedItem="{Binding SelectedProfile}"
                         Style="{StaticResource DarkListBox}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource DarkListBoxItem}"/>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Color dot -->
                                <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,8,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding ColorTag}"/>
                                    </Ellipse.Fill>
                                </Ellipse>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                               Foreground="#E6EDF3"/>
                                    <TextBlock FontSize="11" Foreground="#8B949E">
                                        <Run Text="ID: "/><Run Text="{Binding Id, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding Status}" 
                                           FontSize="11" Foreground="#8B949E"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ═══ Bottom Actions ═══ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="🗑 Delete Selected" 
                    Command="{Binding DeleteCommand}" 
                    Style="{StaticResource DangerButton}"
                    Margin="0,0,8,0"/>
            <Button Content="Close" 
                    Style="{StaticResource DarkButton}"
                    Click="OnCloseClick"/>
        </StackPanel>
    </Grid>
</Window>
